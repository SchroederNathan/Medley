{
  "expo": {
    "name": "Medley - Track & Discover",
    "slug": "medley",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "com.schroedernathan.medley",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.schroedernathan.medley"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon/foreground.png",
        "backgroundColor": "#171717"
      },
      "package": "com.schroedernathan.medley"
    },
    "web": {
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/icons/splash.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0A0A0A",
            "image": "./assets/icons/splash.png",
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-asset",
        {
          "assets": ["./assets/rive/warp_circle.riv"]
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "schroeder-nathan"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/icon.png",
          "color": "#171717",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Medley to use your location to show movie showtimes at theaters near you."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9b4bb48-9ccf-4ba5-a2f9-9afe99770ee4"
      }
    },
    "experiments": {
      "reactCompiler": true
    }
  }
}
